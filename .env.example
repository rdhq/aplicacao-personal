# =========================================================
# MODO DEMO (roda sem banco, sem autenticação, com dados mock)
# Deixe true para mostrar o ambiente sem configurar nada.
# Mude para false quando for configurar o banco real.
# =========================================================
NEXT_PUBLIC_DEMO_MODE="true"

# =========================================================
# MODO PRODUÇÃO (Supabase)
# Preencha apenas quando for usar com banco real.
# Neste caso, defina NEXT_PUBLIC_DEMO_MODE="false" acima.
# =========================================================

# PostgreSQL via Supabase pooler (Transaction mode, porta 6543)
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Auth (copiar de Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"